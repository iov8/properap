# Browser-visible Supabase configuration. These values are safe for the browser
# only when database Row Level Security policies are correctly enabled.
NEXT_PUBLIC_SUPABASE_URL=https://wtwvdweaunasdoyuafsb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Canonical public address used for trusted redirects and generated links.
NEXT_PUBLIC_APP_URL=https://steadfast.rockhillinnovation.com

# Server-only values must never use the NEXT_PUBLIC_ prefix.
# Add them directly in Vercel, not in this file or the Git repository.
# SUPABASE_SECRET_KEY=sb_secret_your-server-only-key

# Server-only rate updater. Add both values in Vercel; never prefix them with NEXT_PUBLIC_.
# OPEN_EXCHANGE_RATES_APP_ID=your-open-exchange-rates-app-id
# CRON_SECRET=use-a-random-string-of-at-least-32-characters
